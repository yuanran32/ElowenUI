{
  "name": "@elowen/elowen-ui",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "A lightweight Vue 3 component library with docs, playground demos, typed APIs and build output.",
  "author": "elowen",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "ui",
    "typescript",
    "vite",
    "vitepress"
  ],
  "homepage": "https://github.com/yuanran32/ElowenUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuanran32/ElowenUI.git"
  },
  "bugs": {
    "url": "https://github.com/yuanran32/ElowenUI/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/elowen-ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/elowen-ui/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/alert": {
      "types": "./dist/types/components/alert/index.d.ts",
      "import": "./dist/components/alert/index.js"
    },
    "./components/button": {
      "types": "./dist/types/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./components/card": {
      "types": "./dist/types/components/card/index.d.ts",
      "import": "./dist/components/card/index.js"
    },
    "./components/dialog": {
      "types": "./dist/types/components/dialog/index.d.ts",
      "import": "./dist/components/dialog/index.js"
    },
    "./components/divider": {
      "types": "./dist/types/components/divider/index.d.ts",
      "import": "./dist/components/divider/index.js"
    },
    "./components/form": {
      "types": "./dist/types/components/form/index.d.ts",
      "import": "./dist/components/form/index.js"
    },
    "./components/input": {
      "types": "./dist/types/components/input/index.d.ts",
      "import": "./dist/components/input/index.js"
    },
    "./components/pro-table": {
      "types": "./dist/types/components/pro-table/index.d.ts",
      "import": "./dist/components/pro-table/index.js"
    },
    "./components/schema-form": {
      "types": "./dist/types/components/schema-form/index.d.ts",
      "import": "./dist/components/schema-form/index.js"
    },
    "./components/select": {
      "types": "./dist/types/components/select/index.d.ts",
      "import": "./dist/components/select/index.js"
    },
    "./components/table": {
      "types": "./dist/types/components/table/index.d.ts",
      "import": "./dist/components/table/index.js"
    },
    "./components/tag": {
      "types": "./dist/types/components/tag/index.d.ts",
      "import": "./dist/components/tag/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "pnpm -C play dev",
    "build": "vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.17",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.4"
  }
}
